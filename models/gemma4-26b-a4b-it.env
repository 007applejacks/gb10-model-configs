# gemma4-26b-a4b-it.env — gx10 serve recipe for google/gemma-4-26B-A4B-it
# The sparse-MoE sibling of gemma4-31b-it (dense) — same gemma-4 family/generation, but 128
# experts @ top_k=8 routed instead of one dense FFN. On a bandwidth-bound box like GB10, decode
# cost tracks ACTIVE params, not total: dense gemma4-31b-it measured only ~3.7 tok/s (62.5 GB
# weights / 273 GB/s), whereas this checkpoint's per-token traffic is closer to its ~4B active
# params -> potentially much faster, but UNMEASURED — this is the first unquantized-bf16 MoE
# served on gx10 (the other gx10 MoE, nemotron3-nano-30b, runs NVFP4-quantized). Added 2026-07-12,
# first boot not yet verified.
#
# VERIFIED against HF config.json + safetensors index 2026-07-12:
#   arch      Gemma4ForConditionalGeneration -> vLLM "gemma4_mm" (same registry entry as the dense
#             and QAT siblings; gemma4_mm's text tower is gemma4.py, confirmed to implement
#             FusedMoE/num_experts/top_k_experts in the pinned vllm/vllm-openai:v0.24.0 image).
#   moe       128 experts, top_k=8 routed, moe_intermediate_size=704, hidden_size=2816,
#             30 hidden layers (enable_moe_block=true in text_config).
#   quant     NONE — no quantization_config in config.json, dtype=bfloat16 throughout (LM + vision).
#             QUANT=auto omits --quantization (nothing to auto-detect); do NOT force
#             --moe-backend marlin, it requires a quantized MoE (hit on nemotron3-super-120b,
#             see qwen36-agent-tuning/serving-tuning.md) — leave --moe-backend on vLLM's default.
#   size      51.61 GB total (model.safetensors.index.json metadata.total_size), bf16.
#   vision    Same vision tower shape as the 31B siblings (image-text-to-text, 280 soft tokens/image).
#   context   262144 native (text_config.max_position_embeddings), vocab 262144.
#   toolcall  chat_template.jinja macros (format_function_declaration, <|tool_call>call:name{...}
#             <tool_call|>) match the 31B-it-qat template structurally -> gemma4 tool parser applies
#             identically (see gemma4-31b-it-qat.env's TOOL_PARSER fix, 2026-07-12).

SERVE_MODEL=google/gemma-4-26B-A4B-it
SERVED_NAME=gemma4-26b-a4b-it
SERVE_CONTAINER=swap-vllm-gemma4-26b-a4b-it

# --- swap-ui loader-bay card (display-only; no re-serve needed to change) ---
UI_LABEL="Gemma 4 26B-A4B-it (MoE)"
UI_DESC="Sparse-MoE gemma-4, 128 experts/top_k=8 (~4B active). Same multimodal 256K family as the dense/QAT gemma-4 builds, unquantized bf16. First MoE-bf16 serve on gx10 -- validated 2026-07-13: tool-calling confirmed (gemma4 parser), decode ~6.4x the bf16 dense sibling."
UI_SIZE="~51.6 GB · 26B MoE (4B active) · MM · 256K ctx"
# UI_SPEED: informal single-request sample 2026-07-13 (192 completion tokens / 8.1s wall,
# includes prefill -- not an isolated decode-only measurement), NOT a full GenBench v1 run.
# 23.6 tok/s vs the ~34 tok/s theoretical active-param-bandwidth ceiling (routing/attention/
# non-expert-layer overhead accounts for the gap, as expected) -- still ~2.2x the int4-QAT dense
# sibling's 10.6 tok/s and ~6.4x the bf16 dense sibling's 3.7 tok/s. Replace with a real GenBench
# v1 run for a load-bearing number.
UI_SPEED="~23.6 tok/s (informal single-request sample, not GenBench)"
UI_USE_CASES="X++ / D365FO dev, screenshot & vision Q&A, long-context reading"
# EXPERIMENTAL: first unquantized-bf16 MoE on gx10 -- MoE kernel path (FusedMoE, non-marlin
# backend) unproven on GB10 until first boot; treat throughput/tool-call reliability as unverified.
EXPERIMENTAL=1

# No quantization_config in the checkpoint -> nothing to auto-detect, QUANT=auto omits the flag.
QUANT=auto

MAX_LEN=262144
KV_ARG="--kv-cache-dtype bfloat16"

# --- Qwen3.6 recipe fields cleared (same rationale as the other gemma-4 builds: not a Qwen
# thinking model by default -- the chat template DOES have a thinking channel, but only when
# enable_thinking is explicitly turned on, which none of these recipes do) ---
REASONING_PARSER=""
SPEC_ARG=""
COMPILE_ARG=""

# Tool calling ON with vLLM 0.24's dedicated gemma4 parser (see gemma4-31b-it-qat.env's 2026-07-12
# fix for the full story: without these flags, any request carrying a `tools` array 400s in-stream).
TOOLS=1
TOOL_PARSER=gemma4

# Gemma sampling profile, matches the other gemma-4 builds (per-request values override).
GENCFG_ARG="--override-generation-config '{\"temperature\": 1.0, \"top_p\": 0.95, \"top_k\": 64}'"

# Keep multimodal ON, capped at 4 images/prompt (single-quoted JSON must survive the gx10_ssh hop).
EXTRA_ARGS="--limit-mm-per-prompt '{\"image\":4}'"
