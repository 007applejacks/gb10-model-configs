# gemma4-31b-it-qat.env — gx10 serve recipe for google/gemma-4-31B-it-qat-w4a16-ct
# The int4 quantization-aware-trained (W4A16) sibling of gemma4-31b-it, added 2026-07-12 to
# recover decode speed: bf16 gemma4-31b-it measured only ~3.7 tok/s (bandwidth-bound on 62.5 GB
# weights / GB10's 273 GB/s). This checkpoint is ~23.3 GB -> ~2.7x less memory traffic per token.
#
# VERIFIED against HF config.json 2026-07-12:
#   arch      Gemma4ForConditionalGeneration -> vLLM "gemma4_mm" (same as bf16; supported in 0.24.0).
#   quant     compressed-tensors, format=pack-quantized, int4 W4A16, group_size 32, symmetric.
#             vLLM auto-detects from quantization_config -> QUANT=auto omits --quantization.
#             GB10 already runs Marlin W4A16 kernels (see gb10 serving.md), so the kernel path exists.
#   vision    vision_tower is in the quant "ignore" list -> stays unquantized (image quality preserved).
#   size      ~23.3 GB weights (int4 LM + bf16 vision tower).

SERVE_MODEL=google/gemma-4-31B-it-qat-w4a16-ct
SERVED_NAME=gemma4-31b-it-qat
SERVE_CONTAINER=swap-vllm-gemma4-31b-it-qat

# --- swap-ui loader-bay card (display-only; no re-serve needed to change) ---
UI_LABEL="Gemma 4 31B-it (int4-QAT)"
UI_DESC="int4 quantization-aware-trained gemma-4-31B-it. Same multimodal 256K model, ~2.7x smaller weights for faster decode. Vision tower left unquantized."
UI_SIZE="~23 GB · 31B dense int4 · MM · 256K ctx"
# UI_SPEED: measured 2026-07-12 via GenBench v1 — ~10.6 tok/s single-stream decode
# (2.9x the bf16 sibling's 3.7; ~23 GB weights vs 62.5 on GB10's 273 GB/s).
UI_SPEED="~10.6 tok/s"
UI_USE_CASES="X++ / D365FO dev, screenshot & vision Q&A, long-context reading"
# EXPERIMENTAL: brand-new (post-cutoff) + int4 quant kernel path unproven on GB10 until first boot.
EXPERIMENTAL=1

# compressed-tensors int4 is auto-detected from quantization_config -> no --quantization flag.
QUANT=auto

# --- Context: full native 256K. With ~23 GB weights (vs 62.5) the KV pool is far larger than the
# bf16 build (which already got 1.85x at 256K), so 262144 fits with lots of concurrency headroom.
# VERIFY the reported "Maximum concurrency" at boot; raise nothing, it's already native max.
MAX_LEN=262144
KV_ARG="--kv-cache-dtype bfloat16"

# --- Qwen3.6 recipe fields cleared (same rationale as the bf16 gemma build) ---
REASONING_PARSER=""
SPEC_ARG=""
COMPILE_ARG=""

# Tool calling ON with vLLM 0.24's dedicated gemma4 parser. Added 2026-07-12 after a swap to this
# model broke Hermes CLI / Copilot: without these flags any request carrying a `tools` array gets a
# 400 ("auto" tool choice requires --enable-auto-tool-choice/--tool-call-parser) inside the SSE
# stream. Parser choice verified against the checkpoint's chat_template.jinja: gemma-4 emits
# <|tool_call>call:name{...}<tool_call|> — the gemma4 parser's format, NOT gemma-3's pythonic.
TOOLS=1
TOOL_PARSER=gemma4

# Gemma sampling profile (per-request values override).
GENCFG_ARG="--override-generation-config '{\"temperature\": 1.0, \"top_p\": 0.95, \"top_k\": 64}'"

# Keep multimodal ON, capped at 4 images/prompt (single-quoted JSON must survive the gx10_ssh hop).
EXTRA_ARGS="--limit-mm-per-prompt '{\"image\":4}'"
