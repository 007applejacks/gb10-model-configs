# gemma4-31b-it.env — gx10 serve recipe for google/gemma-4-31B-it
# Sourced by gx10-serve.sh via SERVE_ENV_FILE (and parsed by the swap-ui).
# Built clean 2026-07-12 from the model's own config.json + vLLM 0.24.0 registry,
# NOT copied from the Qwen/Nemotron recipes — none of their tuning applies here.
#
# WHAT THIS MODEL IS (verified against HF config.json 2026-07-12):
#   arch      Gemma4ForConditionalGeneration -> vLLM "gemma4_mm" (MULTIMODAL, text+image).
#             Supported in our pinned vllm/vllm-openai:v0.24.0-aarch64 (registry has it).
#   dense     enable_moe_block=false. NOT a MoE — no --moe-* flags.
#   dtype     bfloat16, unquantized. Weights = 62.5 GB (safetensors index total_size).
#   attn      60 layers = 50 sliding_attention (window 1024, head_dim 256)
#                        + 10 full_attention (head_dim 512), 16 KV-heads. Hybrid.
#   ctx       native 262144 (256K).
#
# MULTIMODAL IS ON BY DESIGN: Nathan pastes screenshots into X++ dev, so the vision
# path stays enabled (see EXTRA_ARGS). This is why the -it (mm) checkpoint was chosen
# over any text-only build (there is no text-only 31B anyway).

SERVE_MODEL=google/gemma-4-31B-it
SERVED_NAME=gemma4-31b-it
SERVE_CONTAINER=swap-vllm-gemma4-31b-it

# bf16 checkpoint: no quantization to detect -> auto omits --quantization.
QUANT=auto

# --- Context length: sized to leave real KV headroom (see math below) ---
# Budget: 121 GB * 0.85 = 102.85 GB. Weights 62.5 GB + ~6 GB vLLM overhead
# -> ~34 GB KV pool. KV grows only on the 10 full_attention layers:
#   10 * 16 kv-heads * 512 head_dim * 2(K+V) * 2 bytes = 320 KiB/token.
#   (50 sliding layers are capped at the 1024 window = ~0.8 GB fixed, do NOT grow.)
# 64K seq -> ~21 GB -> ~1.5x concurrency = comfortable room. Single-seq ceiling ~100K.
# VERIFY at boot: vLLM prints "GPU KV cache size" / "Maximum concurrency ... Nx" —
# if the real pool is bigger than this estimate, raise MAX_LEN then; if OOM, lower.
MAX_LEN=65536

# KV dtype bf16 = accuracy-safe default (repo lesson: fp8 KV w/ uncalibrated scales
# is an accuracy bug). Switching to fp8 would ~double context but trade accuracy.
KV_ARG="--kv-cache-dtype bfloat16"

# --- Qwen3.6 recipe fields explicitly CLEARED (wrong/invalid for gemma-4) ---
REASONING_PARSER=""   # not a Qwen thinking model; no <think> stream to strip
SPEC_ARG=""           # MTP draft is Qwen's. vLLM has gemma4_mtp, but this checkpoint
                      # is not confirmed to ship an MTP head — leave off until tested.
COMPILE_ARG=""        # only existed to guard MTP spec-decode; drop with SPEC.

# Gemma sampling profile (Gemma family recommendation; per-request values override).
GENCFG_ARG="--override-generation-config '{\"temperature\": 1.0, \"top_p\": 0.95, \"top_k\": 64}'"

# --- EXTRA vLLM args ---
# Keep multimodal ON, capped at 4 images/prompt (screenshots). Each image also spends
# context tokens, so this trades against MAX_LEN. Single-quoted JSON must survive the
# gx10_ssh hop — verify it reaches vLLM intact on first serve.
EXTRA_ARGS="--limit-mm-per-prompt '{\"image\":4}'"

# TOOLS deliberately left OFF: gemma-4 has a native function-call template, but the
# qwen3_xml parser gx10-serve.sh would attach does NOT match it, and vLLM 0.24.0 has no
# verified gemma tool parser. Enable only after picking/validating a correct parser.

# Boot backend caution: gemma-4 uses sliding-window + logit softcapping
# (final_logit_softcapping=30.0). If vLLM errors that the attention backend lacks
# softcapping/sliding support, set VLLM_ATTENTION_BACKEND=FLASHINFER — that's a
# CONTAINER env var (needs a `-e` in gx10-serve.sh's docker run), NOT a vLLM CLI arg,
# so it can't live in EXTRA_ARGS. Likely unneeded on Blackwell (FlashInfer default).
