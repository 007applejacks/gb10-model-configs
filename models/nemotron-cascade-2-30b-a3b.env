# UI-imported model recipe (host-local; gitignored). Promote via Export to version it.
# Tuning knobs (spec-decode/KV/sampling) are pinned OFF — validate + tune before trusting.
# GPU_UTIL set to 0.65 (not the 0.85 import default), matching the box's only other large-MoE
# recipe (nemotron3-super-120b) given known OOM/wedge risk on this hardware. EXTRA_ARGS's
# --max-num-seqs flag was a single-dash typo in the original import; fixed to double-dash so
# vLLM actually parses it. SPEC_ARG/COMPILE_ARG explicitly disabled: this checkpoint hit
# NotImplementedError: Unsupported speculative method: 'mtp' from vLLM 0.24 on first load —
# gb10-serve.sh's MTP-by-default only applies when SPEC_ARG is left unset.

# --- UI metadata ---
UI_LABEL="Nemotron-Cascade-2-30B-A3B"
UI_DESC="Sparse-MoE Nemotron, 128 experts/top_k=6 (~3B active), unquantized bf16. Validated 2026-07-20: full 9-test stability battery + quality eval (MMLU/GSM8K/BBH/HellaSwag/TruthfulQA) all passed, tool-calling reliable (6/6). No native MTP support on this checkpoint — spec-decode disabled (vLLM 0.24 raised NotImplementedError on first load)."
UI_SIZE="~63 GB · 30B MoE (A3B, ~3B active) · 256K ctx"
UI_SPEED="~27.7 tok/s (offline max throughput ~34.6 tok/s)"
UI_USE_CASES="Agentic tool-use, Long-context reasoning, General-purpose coding"
EXPERIMENTAL="0"

# --- Serve recipe ---
SERVE_MODEL="nvidia/Nemotron-Cascade-2-30B-A3B"
SERVED_NAME="nemotron-cascade-2-30b-a3b"
SERVE_CONTAINER="swap-vllm-nemotron-cascade-2-30b-a3b"
SERVE_PORT="8002"
MAX_LEN="262144"
GPU_UTIL="0.65"
QUANT="auto"
TOOLS="1"
REASONING_PARSER="nemotron_v3"
KV_ARG=""
GENCFG_ARG=""
SPEC_ARG=""
COMPILE_ARG=""
EXTRA_ARGS="--max-num-seqs 4"
