# Model registry entry — nemotron3-nano-30b.
#
# NVIDIA-Nemotron-3-Nano-30B-A3B-NVFP4 (30B/A3B MoE). Fastest disciplined option (~62 tok/s,
# 2.4x the 27B) with clean tool-calls. Reasoning parser nemotron_v3. No MTP spec decode was
# configured for this model in testing (already fast), so SPEC_ARG/COMPILE_ARG are cleared.
# KV left at engine default (auto). Served at 131072 ctx (conservative for the Nemotron-3 family;
# A3B KV is tiny so this leaves ample headroom).

# --- UI metadata ---
UI_LABEL="Nemotron-3 Nano 30B — A3B"
UI_DESC="Fast (~142.6 tok/s) and disciplined. Occasional length-cap on long answers, but no reasoning spirals."
UI_SIZE="~19 GB · A3B MoE · 128K ctx · 16 concurrent"
UI_SPEED="~142.6 tok/s (measured 2026-07-22)"
UI_USE_CASES="Fast iteration, Interactive coding, Quick tool-use"
EXPERIMENTAL=0

# --- Serve recipe ---
SERVE_MODEL="nvidia/NVIDIA-Nemotron-3-Nano-30B-A3B-NVFP4"
SERVED_NAME="nemotron3-nano-30b"
SERVE_CONTAINER="swap-vllm-nemotron3-nano-30b"
SERVE_PORT="8002"
MAX_LEN="131072"
GPU_UTIL="0.85"
QUANT="auto"
TOOLS="1"
REASONING_PARSER="nemotron_v3"
KV_ARG=""
GENCFG_ARG=""
SPEC_ARG=""
COMPILE_ARG=""
EXTRA_ARGS="--max-num-seqs 16"  # concurrency cap: swept 2026-07-22 against the uncapped engine (1..96) -- no hard scheduler wall or OOM, throughput just keeps climbing while per-token latency (TPOT) degrades near-linearly (16.6ms at c=1 -> 146.6ms at c=96). 16 is the last point before TPOT crosses ~50ms/tok, matching the same interactive-latency-first policy already applied to qwen36-27b-dense.
