# Model registry entry — nemotron3-super-120b.
#
# NVIDIA-Nemotron-3-Super-120B-A12B-NVFP4 (120B/A12B, ~75 GB). Adopted default from the
# 2026-07-12 throughput follow-up (docs since retired with the old legacy tree): MTP k=3 +
# forced PIECEWISE cudagraph, moe-backend left on auto (~21-25 tok/s). Reasoning parser is
# nemotron_v3 (NOT qwen3). Served at 131072 ctx per NVIDIA's Spark recipe with --max-num-seqs 4.
# KV cache left at engine default (auto -> fp8_e4m3) to match the tested config — bf16 KV was
# never validated on this checkpoint.
#
# GPU_UTIL bumped 0.65 -> 0.80 (2026-07-21): the 0.65 "OOM-risk" value copied over from
# nemotron-cascade-2-30b-a3b was never actually re-validated against THIS model's much larger
# ~75GB footprint -- at 0.65 the engine couldn't even initialize (fatal, not a concurrency
# issue): "4.02 GiB KV cache is needed... available KV cache memory (1.54 GiB)". Confirmed the
# box was fully idle (121GB free) when this hit, so it wasn't memory contention. 0.80 matches
# what's validated on qwen36-27b-dense; watch closely given this model's known OOM/wedge risk.
#
# SPEC_ARG / COMPILE_ARG are left UNSET so gx10-serve.sh's defaults (MTP k=3 + PIECEWISE) apply,
# which is exactly the adopted recipe. KV_ARG="" forces auto (overriding the 27B bf16 default).

# --- UI metadata ---
UI_LABEL="Nemotron-3 Super 120B — A12B"
UI_DESC="Most disciplined: zero truncations, terse reasoning. Slow (~18-28 tok/s) but safest for correctness. Capped at 4 concurrent requests (memory-bound)."
UI_SIZE="~75 GB · A12B MoE · 128K ctx · 4 concurrent"
UI_SPEED="~18-28 tok/s (confirmed 2026-07-21, max-num-seqs=4)"
UI_USE_CASES="Correctness-critical work, Complex reasoning, Long agentic runs"
EXPERIMENTAL=0

# --- Serve recipe ---
SERVE_MODEL="nvidia/NVIDIA-Nemotron-3-Super-120B-A12B-NVFP4"
SERVED_NAME="nemotron3-super-120b"
SERVE_CONTAINER="swap-vllm-nemotron3-super-120b"
SERVE_PORT="8002"
MAX_LEN="131072"
GPU_UTIL="0.80"
QUANT="auto"
TOOLS="1"
REASONING_PARSER="nemotron_v3"
KV_ARG=""
GENCFG_ARG=""
EXTRA_ARGS="--max-num-seqs 4"
