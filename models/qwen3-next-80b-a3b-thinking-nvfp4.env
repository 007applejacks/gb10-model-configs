# UI-imported model recipe (host-local; gitignored). Promote via Export to version it.
# Tuning knobs (spec-decode/KV/sampling) are pinned OFF — validate + tune before trusting.

# --- UI metadata ---
UI_LABEL="Qwen3-Next-80B-A3B-Thinking-NVFP4"
UI_DESC="NOTE: promoted after a concurrency/throughput characterization pass only -- no quality/stability battery (MMLU/GSM8K/tool-calling correctness) run yet, unlike the other committed models on this box. Hybrid GDN(linear)/full-attention MoE, NVFP4. Concurrency swept 2026-07-24: scales cleanly through c=64 (467 tok/s, TTFT P99 7.4s), but c=96 causes a severe engine-level throughput collapse (not OOM -- KV cache stayed under 9%) -- avoid. Capped at 32 for the best throughput/tail-latency balance (355 tok/s, TTFT P99 3.65s)."
UI_SIZE="~47 GB . 80B MoE (A3B, ~3B active) . 256K ctx . 32 concurrent"
UI_SPEED="~104.1 tok/s (measured 2026-07-24)"
UI_USE_CASES="Long-context reasoning,Agentic tool-use,General-purpose coding"
EXPERIMENTAL="0"

# --- Serve recipe ---
SERVE_MODEL="nvidia/Qwen3-Next-80B-A3B-Thinking-NVFP4"
SERVED_NAME="qwen3-next-80b-a3b-thinking-nvfp4"
SERVE_CONTAINER="swap-vllm-qwen3-next-80b-a3b-thinking-nvfp4"
SERVE_PORT="8002"
MAX_LEN="262144"
GPU_UTIL="0.85"
QUANT="modelopt"
TOOLS="1"
REASONING_PARSER="qwen3"
KV_ARG=""
GENCFG_ARG=""
EXTRA_ARGS="--max-num-seqs 32"
SPEC_ARG=""
COMPILE_ARG=""
