# Model registry entry — qwen36-27b-dense (CANONICAL / production default).
#
# Dual-purpose file: sourced by gx10-serve.sh (SERVE_ENV_FILE=...) AND parsed by the
# swap-ui backend (plain KEY="value" lines only — no shell substitution). Values left
# UNSET here fall through to gx10-serve.sh's validated defaults on purpose.
#
# This entry reproduces the live validated container: NVFP4/modelopt, MTP k=3 spec-decode,
# forced PIECEWISE cudagraph, explicit bf16 KV cache, temp 0.6 -- those four come from
# gx10-serve.sh's defaults (SPEC_ARG / COMPILE_ARG / KV_ARG / GENCFG_ARG), so we deliberately
# do NOT set them here. MAX_LEN / GPU_UTIL / EXTRA_ARGS below ARE explicit overrides (64K
# context + 16-concurrent production cap, tuned 2026-07-21 -- see git log for the throughput/
# latency sweeps behind these numbers). The old gpu/docs/*.md tuning docs this used to point to
# no longer exist (retired legacy tree) -- this file + its git history are the source of truth now.

# --- UI metadata (backend only; ignored by the serve script) ---
UI_LABEL="Qwen3.6 27B — dense"
UI_DESC="Canonical production driver. Strong agentic tool-use; MTP-accelerated. Capped at 16 concurrent requests for consistent per-request latency."
UI_SIZE="~20 GB · dense · 64K ctx · 16 concurrent"
UI_SPEED="~60.9 tok/s (measured 2026-07-22)"
UI_USE_CASES="Agentic tool-use, X++/D365FO coding, Production default"
EXPERIMENTAL=0

# --- Serve recipe (sourced by gx10-serve.sh) ---
SERVE_MODEL="nvidia/Qwen3.6-27B-NVFP4"
SERVED_NAME="qwen36-27b-dense"
SERVE_CONTAINER="swap-vllm-qwen36-27b-dense"
SERVE_PORT="8002"
MAX_LEN="65536"
GPU_UTIL="0.80"
QUANT="modelopt"
TOOLS="1"
REASONING_PARSER="qwen3"
EXTRA_ARGS="--max-num-seqs 16"  # production concurrency cap: re-swept 2026-07-21 with the cap active -- 20 showed steep TTFT cliffs once demand exceeds the cap (mean TTFT 8.5s->25.7s at c=32). 16 matches the actual peak-concurrent ceiling seen in the uncapped c=16 sweep (peaked at 20) with less headroom to overshoot.
