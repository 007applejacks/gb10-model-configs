# Model registry entry — qwen36-27b-dense (CANONICAL / production default).
#
# Dual-purpose file: sourced by gx10-serve.sh (SERVE_ENV_FILE=...) AND parsed by the
# swap-ui backend (plain KEY="value" lines only — no shell substitution). Values left
# UNSET here fall through to gx10-serve.sh's validated defaults on purpose.
#
# This entry MUST reproduce the live validated container (see gpu/docs/serving-tuning.md +
# gpu/docs/model-testing-2026-07.md): NVFP4/modelopt, MTP k=3 spec-decode, forced PIECEWISE
# cudagraph, explicit bf16 KV cache, 256K context, temp 0.6. Those come from gx10-serve.sh's
# defaults (SPEC_ARG / COMPILE_ARG / KV_ARG / GENCFG_ARG), so we deliberately do NOT set them.

# --- UI metadata (backend only; ignored by the serve script) ---
UI_LABEL="Qwen3.6 27B — dense"
UI_DESC="Canonical production driver. Strong agentic tool-use; MTP-accelerated (~65 tok/s)."
UI_SIZE="~20 GB · dense · 256K ctx"
UI_SPEED="~64.8 tok/s (measured 2026-07-20)"
UI_USE_CASES="Agentic tool-use, X++/D365FO coding, Production default"
EXPERIMENTAL=0

# --- Serve recipe (sourced by gx10-serve.sh) ---
SERVE_MODEL="nvidia/Qwen3.6-27B-NVFP4"
SERVED_NAME="qwen36-27b-dense"
SERVE_CONTAINER="swap-vllm-qwen36-27b-dense"
SERVE_PORT="8002"
MAX_LEN="262144"
GPU_UTIL="0.80"
QUANT="modelopt"
TOOLS="1"
REASONING_PARSER="qwen3"
