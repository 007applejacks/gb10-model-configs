# Model registry entry — qwen36-35b-a3b.
#
# Qwen3.6-35B-A3B-NVFP4 (~22 GB, A3B MoE). NVIDIA's reference Spark default. Fastest of all four
# (~75 tok/s) but the worst reliability: 3/6 code prompts length-capped, one empty think-loop
# (gpu/docs/model-testing-2026-07.md). Qwen family -> reasoning parser qwen3, bf16 KV (27B default).
# No MTP spec decode was configured for this model in testing, so SPEC_ARG/COMPILE_ARG are cleared.
# KV_ARG left UNSET -> inherits the validated bf16 default; GENCFG (temp 0.6) inherited likewise.

# --- UI metadata ---
UI_LABEL="Qwen3.6 35B — A3B"
UI_DESC="Fastest (~75 tok/s) but least reliable — prone to length caps / reasoning spirals on long code."
UI_SIZE="~22 GB · A3B MoE · 256K ctx"
EXPERIMENTAL=0

# --- Serve recipe ---
SERVE_MODEL="nvidia/Qwen3.6-35B-A3B-NVFP4"
SERVED_NAME="qwen36-35b-a3b"
SERVE_CONTAINER="swap-vllm-qwen36-35b-a3b"
SERVE_PORT="8002"
MAX_LEN="262144"
GPU_UTIL="0.85"
QUANT="auto"
TOOLS="1"
REASONING_PARSER="qwen3"
